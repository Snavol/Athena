<%- include('header') %>

    <!-- Main Content -->
    <main id="main-content">
        <!-- Hero Section -->
        <section class="hero">
            <div class="hero-content">
                <div class="hero-text fade-in">
                    <!-- <div class="hero-badge">
                        <span>★</span> Featured Novel of the Month
                    </div> -->
                    <h1>The Dragon's<br>Last Heir</h1>
                    <p>In a world where magic has faded to myth, a forgotten bloodline awakens. Elara must navigate political intrigue and ancient curses to reclaim her birthright before the realm crumbles.</p>
                    <div class="hero-stats">
                        <div class="stat">
                            <span class="stat-value">2.4M</span>
                            <span class="stat-label">Readers</span>
                        </div>
                        <div class="stat">
                            <span class="stat-value">4.9</span>
                            <span class="stat-label">Rating</span>
                        </div>
                        <div class="stat">
                            <span class="stat-value">342</span>
                            <span class="stat-label">Chapters</span>
                        </div>
                    </div>
                    <div class="hero-actions">
                        <button class="btn btn-primary" onclick="openNovelDetail('The Dragon\'s Last Heir')">
                            Start Reading
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M5 12h14M12 5l7 7-7 7"/>
                            </svg>
                        </button>
                        <button class="btn btn-ghost" onclick="toggleBookmark(this)">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
                            </svg>
                            Add to Library
                        </button>
                    </div>
                </div>
                <div class="hero-visual fade-in stagger-2">
                    <div class="book-showcase">
                        <div class="book-cover">
                            <div class="book-decoration"></div>
                            <div class="book-title">The Dragon's<br>Last Heir</div>
                            <div class="book-author">by Elena Vance</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Trending Section -->
        <section class="section">
            <div class="section-header reveal">
                <h2 class="section-title">Trending Now</h2>
                <a class="view-all" onclick="showView('browse')">
                    View All 
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                </a>
            </div>
            <div class="novel-grid" id="trending-grid">
                <!-- Generated by JS -->
            </div>
        </section>

        <!-- Popular Section -->
        <section class="section">
            <div class="section-header reveal">
                <h2 class="section-title">Popular This Week</h2>
                <a class="view-all" onclick="showView('browse')">
                    View All
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                </a>
            </div>
            <div class="novel-grid" id="popular-grid">
                <!-- Generated by JS -->
            </div>
        </section>

        <!-- Recently Updated -->
        <section class="section" style="margin-bottom: 4rem;">
            <div class="section-header reveal">
                <h2 class="section-title">Recently Updated</h2>
                <a class="view-all" onclick="showView('browse')">
                    View All
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                </a>
            </div>
            <div class="novel-grid" id="recent-grid">
                <!-- Generated by JS -->
            </div>
        </section>
    </main>

    <!-- Novel Detail View -->
    <div class="novel-detail" id="novel-detail">
        <div class="detail-hero">
            <div class="detail-content">
                <div class="detail-cover" id="detail-cover"></div>
                <div class="detail-info">
                    <div class="hero-badge" style="width: fit-content;">
                        <span>●</span> Ongoing
                    </div>
                    <h1 id="detail-title">Novel Title</h1>
                    <div class="detail-meta">
                        <div class="detail-meta-item">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                <circle cx="12" cy="7" r="4"/>
                            </svg>
                            <span id="detail-author">Author Name</span>
                        </div>
                        <div class="detail-meta-item">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                            </svg>
                            <span>4.8 Rating</span>
                        </div>
                        <div class="detail-meta-item">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                            <span>1.2M Views</span>
                        </div>
                    </div>
                    <p style="color: var(--text-muted); line-height: 1.8; max-width: 600px;" id="detail-desc">
                        Description goes here...
                    </p>
                    <div class="detail-actions">
                        <button class="btn btn-primary" onclick="startReading()">
                            Read Now
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M5 12h14M12 5l7 7-7 7"/>
                            </svg>
                        </button>
                        <button class="btn btn-ghost" onclick="toggleBookmark(this)">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
                            </svg>
                            Bookmark
                        </button>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="chapters-list" id="chapters-list">
            <h3 style="font-family: var(--font-title); margin-bottom: 2rem; font-size: 1.5rem;">Chapters</h3>
            <!-- Generated by JS -->
        </div>
        
        <div style="text-align: center; padding: 4rem;">
            <button class="btn btn-ghost" onclick="closeNovelDetail()">Back to Browse</button>
        </div>
    </div>

    <!-- Reader View -->
    <div class="reader" id="reader">
        <div class="reader-progress" id="reader-progress" style="width: 0%"></div>
        
        <div class="reader-header" id="reader-header">
            <div class="reader-title" id="reader-title">Chapter 1</div>
            <div class="reader-controls">
                <div class="font-control">
                    <button class="font-btn" onclick="changeFontSize(-1)">A-</button>
                    <span style="font-size: 0.8rem;">Size</span>
                    <button class="font-btn" onclick="changeFontSize(1)">A+</button>
                </div>
                <button class="icon-btn" onclick="closeReader()" title="Close">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 6L6 18M6 6l12 12"/>
                    </svg>
                </button>
            </div>
        </div>

        <div class="reader-content" id="reader-content">
            <h2>Prologue: The Awakening</h2>
            <p>The autumn wind carried whispers of change through the ancient streets of Velaris. Elara stood at the window of her tower chamber, watching the last golden leaves detach themselves from the ancient oak tree in the courtyard below. Each spiral descent seemed to mirror the slow unraveling of her ordinary life—a life she had carefully constructed over twenty-three years of deliberate obscurity.</p>
            
            <p>It began with the dreams. At first, she dismissed them as the product of too many hours spent poring over her grandmother's dusty journals. But when the visions started bleeding into her waking hours—flashes of scales like molten gold, wings that eclipsed the sun, and eyes that held the wisdom of ages—she could no longer deny that something ancient was stirring within her blood.</p>
            
            <p>The mark appeared on the eve of the Harvest Moon. A delicate pattern of interlocking spirals, glowing with a faint golden light, etched itself across her left shoulder blade. It didn't hurt, exactly. Rather, it felt like coming home after a journey so long that the memory of departure had faded into myth.</p>
            
            <p>"Dragon-born," the old midwife had whispered when Elara was born, before the Queen's soldiers had taken her away to ensure the bloodline ended. Her mother had died protecting her secret, and her father... well, her father had been something else entirely. Something that slept beneath the mountain for a thousand years.</p>
            
            <p>Now, standing before the mirror with her nightgown pulled aside, Elara traced the glowing mark with trembling fingers. The room grew warm, impossibly warm for an autumn evening, and in the reflection, just behind her shoulder, she caught a glimpse of eyes burning with amber fire.</p>
            
            <p>"It is time," a voice rumbled, not through the air but through her very bones. "The last heir must claim the throne before the shadow consumes all."</p>
            
            <p>Outside, the bells of Velaris began to ring—not the measured tolling of the hour, but a frantic, desperate clamor that spoke of danger and destiny intertwined. Elara closed her eyes, feeling the power unfurl within her like wings stretching after centuries of slumber.</p>
            
            <p>When she opened them again, the girl who had been afraid of her own shadow was gone. In her place stood someone who had no choice but to become legend.</p>
            
            <p>And somewhere in the distance, a dragon roared.</p>
        </div>

        <div class="reader-nav">
            <button class="btn btn-ghost" onclick="prevChapter()">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 12H5M12 19l-7-7 7-7"/>
                </svg>
                Previous
            </button>
            <button class="btn btn-primary" onclick="nextChapter()">
                Next Chapter
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
            </button>
        </div>
    </div>

    <script>
        // Novel Data
        const novels = [
            { title: "Shadows of Eternity", author: "Marcus Chen", tag: "Fantasy", desc: "When the veil between worlds tears, a reluctant hero must bridge the gap.", rating: "4.7", views: "890K", chapters: 156 },
            { title: "Neon Samurai", author: "Yuki Tanaka", tag: "Sci-Fi", desc: "In Neo-Tokyo 2187, honor is coded in blood and circuitry.", rating: "4.9", views: "1.2M", chapters: 89 },
            { title: "The Alchemist's Daughter", author: "Sarah Winters", tag: "Historical", desc: "Forbidden magic and forbidden love in Renaissance Florence.", rating: "4.6", views: "650K", chapters: 210 },
            { title: "Void Walker", author: "Alex Kade", tag: "Horror", desc: "Some doors, once opened, cannot be closed. Some walkers cannot be stopped.", rating: "4.8", views: "430K", chapters: 67 },
            { title: "Celestial Academy", author: "Luna Star", tag: "Romance", desc: "Falling in love was never part of the curriculum at the Academy of Stars.", rating: "4.5", views: "2.1M", chapters: 312 },
            { title: "Iron Crown", author: "James Hollow", tag: "Political", desc: "Power is a game, and the crown is the ultimate prize.", rating: "4.7", views: "780K", chapters: 145 },
            { title: "Whispering Woods", author: "Elena Green", tag: "Mystery", desc: "The trees remember everything. The question is, who listens?", rating: "4.4", views: "320K", chapters: 98 },
            { title: "Starbound", author: "Nova Chen", tag: "Adventure", desc: "Across galaxies, one ship carries the last hope of humanity.", rating: "4.9", views: "1.5M", chapters: 234 }
        ];

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            renderNovels();
            initScrollEffects();
            initParticles();
            
            // Navbar scroll effect
            window.addEventListener('scroll', () => {
                const nav = document.getElementById('navbar');
                if (window.scrollY > 50) {
                    nav.classList.add('scrolled');
                } else {
                    nav.classList.remove('scrolled');
                }
                
                // Reader progress
                updateReaderProgress();
            });

            // Reader header show/hide
            let lastScroll = 0;
            const reader = document.getElementById('reader');
            reader.addEventListener('scroll', () => {
                const header = document.getElementById('reader-header');
                const currentScroll = reader.scrollTop;
                
                if (currentScroll > lastScroll && currentScroll > 100) {
                    header.classList.remove('visible');
                } else {
                    header.classList.add('visible');
                }
                lastScroll = currentScroll;
                
                updateReaderProgress();
            });
        });

        function renderNovels() {
            const trending = document.getElementById('trending-grid');
            const popular = document.getElementById('popular-grid');
            const recent = document.getElementById('recent-grid');
            
            novels.forEach((novel, index) => {
                const card = createNovelCard(novel, index);
                if (index < 4) trending.appendChild(card.cloneNode(true));
                if (index >= 2 && index < 6) popular.appendChild(card.cloneNode(true));
                recent.appendChild(card.cloneNode(true));
            });
        }

        function createNovelCard(novel, index) {
            const div = document.createElement('div');
            div.className = 'novel-card reveal';
            div.style.transitionDelay = `${index * 0.1}s`;
            div.innerHTML = `
                <div class="novel-card-image" style="background: linear-gradient(135deg, hsl(${index * 45}, 40%, 15%), hsl(${index * 45 + 30}, 30%, 10%));">
                    <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-family: var(--font-title); font-size: 1.5rem; color: var(--primary); opacity: 0.3;">
                        ${novel.title.charAt(0)}
                    </div>
                </div>
                <div class="novel-card-content">
                    <span class="novel-card-tag">${novel.tag}</span>
                    <h3>${novel.title}</h3>
                    <p>${novel.desc}</p>
                    <div class="novel-card-meta">
                        <div class="novel-card-stats">
                            <div class="stat-item">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                                </svg>
                                ${novel.rating}
                            </div>
                            <div class="stat-item">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                                ${novel.views}
                            </div>
                        </div>
                        <button class="bookmark-btn" onclick="event.stopPropagation(); toggleBookmark(this)">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
                            </svg>
                        </button>
                    </div>
                </div>
            `;
            div.onclick = () => openNovelDetail(novel.title, novel.author, novel.desc);
            return div;
        }

        function initScrollEffects() {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, { threshold: 0.1 });

            document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
            
            // Initial fade in
            setTimeout(() => {
                document.querySelectorAll('.fade-in').forEach(el => el.classList.add('visible'));
            }, 300);
        }

        function showView(view) {
            // Update nav active state
            document.querySelectorAll('.nav-links a').forEach(a => a.classList.remove('active'));
            event.target.classList.add('active');
            
            // Scroll to section or show placeholder
            if (view === 'home') {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        }

        function openNovelDetail(title, author, desc) {
            const detail = document.getElementById('novel-detail');
            document.getElementById('detail-title').textContent = title || 'The Dragon\'s Last Heir';
            document.getElementById('detail-author').textContent = author || 'Elena Vance';
            document.getElementById('detail-desc').textContent = desc || 'In a world where magic has faded to myth, a forgotten bloodline awakens...';
            
            // Generate chapters
            const chaptersList = document.getElementById('chapters-list');
            chaptersList.innerHTML = '<h3 style="font-family: var(--font-title); margin-bottom: 2rem; font-size: 1.5rem;">Chapters</h3>';
            for (let i = 1; i <= 10; i++) {
                const chapter = document.createElement('div');
                chapter.className = `chapter-item ${i < 3 ? 'read' : ''}`;
                chapter.innerHTML = `
                    <span class="chapter-number">Ch. ${i}</span>
                    <span class="chapter-title">${getChapterTitle(i)}</span>
                    <span class="chapter-date">${getRandomDate()}</span>
                `;
                chapter.onclick = () => startReading(i);
                chaptersList.appendChild(chapter);
            }
            
            detail.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeNovelDetail() {
            document.getElementById('novel-detail').classList.remove('active');
            document.body.style.overflow = '';
        }

        function startReading(chapter = 1) {
            document.getElementById('reader').classList.add('active');
            document.getElementById('reader-header').classList.add('visible');
            document.getElementById('reader-title').textContent = `Chapter ${chapter}: ${getChapterTitle(chapter)}`;
            document.body.style.overflow = 'hidden';
            
            // Reset scroll
            document.getElementById('reader').scrollTop = 0;
        }

        function closeReader() {
            document.getElementById('reader').classList.remove('active');
            document.body.style.overflow = '';
        }

        function updateReaderProgress() {
            const reader = document.getElementById('reader');
            if (!reader.classList.contains('active')) return;
            
            const scrollTop = reader.scrollTop;
            const scrollHeight = reader.scrollHeight - reader.clientHeight;
            const progress = (scrollTop / scrollHeight) * 100;
            document.getElementById('reader-progress').style.width = progress + '%';
        }

        function changeFontSize(delta) {
            const content = document.getElementById('reader-content');
            const current = parseFloat(getComputedStyle(content).fontSize);
            const newSize = Math.max(14, Math.min(24, current + delta));
            content.style.fontSize = newSize + 'px';
        }

        function toggleBookmark(btn) {
            btn.classList.toggle('active');
            const svg = btn.querySelector('svg');
            if (btn.classList.contains('active')) {
                svg.setAttribute('fill', 'currentColor');
                btn.style.transform = 'scale(1.2)';
                setTimeout(() => btn.style.transform = 'scale(1)', 200);
            } else {
                svg.setAttribute('fill', 'none');
            }
        }

        function toggleTheme() {
            const html = document.documentElement;
            const current = html.getAttribute('data-theme');
            html.setAttribute('data-theme', current === 'dark' ? 'light' : 'dark');
        }

        function prevChapter() {
            // Animation for page turn
            const content = document.getElementById('reader-content');
            content.style.opacity = '0';
            content.style.transform = 'translateX(50px)';
            setTimeout(() => {
                content.style.opacity = '1';
                content.style.transform = 'translateX(0)';
            }, 300);
        }

        function nextChapter() {
            const content = document.getElementById('reader-content');
            content.style.opacity = '0';
            content.style.transform = 'translateX(-50px)';
            setTimeout(() => {
                content.style.opacity = '1';
                content.style.transform = 'translateX(0)';
            }, 300);
        }

        function getChapterTitle(n) {
            const titles = [
                "The Awakening", "First Blood", "The Council", "Ancient Secrets",
                "Dragon's Breath", "The Betrayal", "Blood and Gold", "The Last Stand",
                "Rebirth", "Epilogue: New Dawn"
            ];
            return titles[n - 1] || `Chapter ${n}`;
        }

        function getRandomDate() {
            const days = Math.floor(Math.random() * 30);
            return `${days} days ago`;
        }

        // Particle System
        function initParticles() {
            const canvas = document.getElementById('particles');
            const ctx = canvas.getContext('2d');
            let particles = [];
            
            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            resize();
            window.addEventListener('resize', resize);
            
            class Particle {
                constructor() {
                    this.reset();
                }
                
                reset() {
                    this.x = Math.random() * canvas.width;
                    this.y = Math.random() * canvas.height;
                    this.size = Math.random() * 2;
                    this.speedX = (Math.random() - 0.5) * 0.5;
                    this.speedY = (Math.random() - 0.5) * 0.5;
                    this.opacity = Math.random() * 0.5;
                }
                
                update() {
                    this.x += this.speedX;
                    this.y += this.speedY;
                    
                    if (this.x < 0 || this.x > canvas.width || this.y < 0 || this.y > canvas.height) {
                        this.reset();
                    }
                }
                
                draw() {
                    ctx.fillStyle = `rgba(212, 175, 55, ${this.opacity})`;
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                    ctx.fill();
                }
            }
            
            for (let i = 0; i < 50; i++) {
                particles.push(new Particle());
            }
            
            function animate() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                particles.forEach(p => {
                    p.update();
                    p.draw();
                });
                
                // Connect particles
                particles.forEach((p1, i) => {
                    particles.slice(i + 1).forEach(p2 => {
                        const dx = p1.x - p2.x;
                        const dy = p1.y - p2.y;
                        const dist = Math.sqrt(dx * dx + dy * dy);
                        
                        if (dist < 150) {
                            ctx.strokeStyle = `rgba(212, 175, 55, ${0.1 * (1 - dist / 150)})`;
                            ctx.lineWidth = 0.5;
                            ctx.beginPath();
                            ctx.moveTo(p1.x, p1.y);
                            ctx.lineTo(p2.x, p2.y);
                            ctx.stroke();
                        }
                    });
                });
                
                requestAnimationFrame(animate);
            }
            animate();
        }
    </script>
</body>
</html>